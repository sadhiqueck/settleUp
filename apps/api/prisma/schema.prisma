generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// ─── Enums ────────────────────────────────────────────

enum GroupCategory {
  TRIP
  HOME
  OFFICE
  ROOMMATES
  FRIENDS
  OTHER
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

enum SplitMethod {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
  ITEMIZED
}

enum ExpenseCategory {
  FOOD
  TRANSPORT
  ACCOMMODATION
  SHOPPING
  ENTERTAINMENT
  UTILITIES
  RENT
  OTHER
}

enum SettlementStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum ActivityType {
  EXPENSE_ADDED
  EXPENSE_UPDATED
  EXPENSE_DELETED
  SETTLEMENT_CREATED
  MEMBER_JOINED
  MEMBER_LEFT
  GROUP_UPDATED
}

enum NotificationType {
  EXPENSE_ADDED
  SETTLEMENT_RECEIVED
  SETTLEMENT_REQUESTED
  GROUP_INVITE
  REMINDER
}

// ─── Models ───────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  avatarUrl        String?
  passwordHash     String?
  googleId         String?  @unique
  isEmailVerified  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  groupMemberships    GroupMember[]
  paidExpenses        Expense[]       @relation("ExpensePaidBy")
  expenseSplits       ExpenseSplit[]
  sentSettlements     Settlement[]    @relation("SettlementPayer")
  receivedSettlements Settlement[]    @relation("SettlementReceiver")
  activityLogs        ActivityLog[]
  notifications       Notification[]
  refreshTokens       RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Group {
  id          String        @id @default(cuid())
  name        String
  description String?
  category    GroupCategory @default(OTHER)
  coverImage  String?
  inviteCode  String        @unique @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  activities  ActivityLog[]

  @@map("groups")
}

model GroupMember {
  id        String    @id @default(cuid())
  userId    String
  groupId   String
  role      GroupRole @default(MEMBER)
  nickname  String?
  joinedAt  DateTime  @default(now())
  isActive  Boolean   @default(true)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@map("group_members")
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Decimal         @db.Decimal(10, 2)
  paidById    String
  groupId     String
  splitMethod SplitMethod     @default(EQUAL)
  category    ExpenseCategory @default(OTHER)
  receiptUrl  String?
  notes       String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  isDeleted   Boolean         @default(false)

  paidBy     User          @relation("ExpensePaidBy", fields: [paidById], references: [id])
  group      Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  splits     ExpenseSplit[]
  activities ActivityLog[]

  @@index([groupId])
  @@index([paidById])
  @@index([date])
  @@map("expenses")
}

model ExpenseSplit {
  id         String   @id @default(cuid())
  expenseId  String
  userId     String
  amount     Decimal  @db.Decimal(10, 2)
  percentage Decimal? @db.Decimal(5, 2)
  shares     Int?
  isPaid     Boolean  @default(false)
  createdAt  DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([userId])
  @@index([expenseId])
  @@map("expense_splits")
}

model Settlement {
  id         String           @id @default(cuid())
  groupId    String
  payerId    String
  receiverId String
  amount     Decimal          @db.Decimal(10, 2)
  status     SettlementStatus @default(CONFIRMED)
  note       String?
  createdAt  DateTime         @default(now())

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer    User  @relation("SettlementPayer",   fields: [payerId],    references: [id])
  receiver User  @relation("SettlementReceiver", fields: [receiverId], references: [id])

  @@index([groupId])
  @@index([payerId])
  @@index([receiverId])
  @@map("settlements")
}

model ActivityLog {
  id        String       @id @default(cuid())
  groupId   String
  userId    String
  type      ActivityType
  expenseId String?
  metadata  Json?
  createdAt DateTime     @default(now())

  group   Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  expense Expense? @relation(fields: [expenseId], references: [id])

  @@index([groupId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}